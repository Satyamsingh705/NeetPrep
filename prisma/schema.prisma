generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Subject {
  PHYSICS
  CHEMISTRY
  BIOLOGY
  MAJOR_TEST
  BOTANY
  ZOOLOGY
}

enum QuestionType {
  TEXT
  IMAGE
}

enum AnswerPolicy {
  SINGLE
  MULTIPLE
  DROPPED
}

enum TestMode {
  CUSTOM
  NEET_PATTERN
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
}

model Student {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  displayName  String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  attempts     Attempt[]
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TestSeriesGroup {
  id          String               @id @default(cuid())
  title       String
  description String?
  orderIndex  Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  documents   TestSeriesDocument[]
}

model Question {
  id             String        @id @default(cuid())
  subject        Subject
  chapter        String
  type           QuestionType
  prompt         String?
  options        Json?
  imagePath      String?
  correctAnswers Json
  answerPolicy   AnswerPolicy  @default(SINGLE)
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  testQuestions  TestQuestion[]
}

model TestSeriesDocument {
  id         String   @id @default(cuid())
  title      String
  fileName   String
  filePath   String
  orderIndex Int      @default(0)
  groupId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  group      TestSeriesGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
}

model Test {
  id                      String         @id @default(cuid())
  testCode                String?        @unique
  name                    String
  description             String?
  durationMinutes         Int
  totalQuestions          Int
  totalEvaluatedQuestions Int
  correctMarks            Int            @default(4)
  incorrectMarks          Int            @default(-1)
  unansweredMarks         Int            @default(0)
  mode                    TestMode       @default(CUSTOM)
  published               Boolean        @default(true)
  config                  Json?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  testQuestions           TestQuestion[]
  attempts                Attempt[]
}

model TestQuestion {
  id         String   @id @default(cuid())
  testId     String
  questionId String
  orderIndex Int
  subject    Subject
  section    String
  chapter    String
  test       Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([testId, orderIndex])
}

model Attempt {
  id                    String        @id @default(cuid())
  testId                String
  studentId             String?
  studentName           String?
  status                AttemptStatus @default(IN_PROGRESS)
  startedAt             DateTime      @default(now())
  submittedAt           DateTime?
  lastSavedAt           DateTime      @updatedAt
  answers               Json
  currentQuestionIndex  Int           @default(1)
  tabSwitchCount        Int           @default(0)
  totalTimeSpentSeconds Int           @default(0)
  result                Json?
  test                  Test          @relation(fields: [testId], references: [id], onDelete: Cascade)
  student               Student?      @relation(fields: [studentId], references: [id], onDelete: SetNull)
}
